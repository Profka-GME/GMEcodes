---
// Import your layout (adjust the path if your layout file has a different name)
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found" description="Oops! We couldn't find that page.">
  <main class="container text-center p-5 my-5">
    <h1 class="display-1 fw-bold text-danger">404</h1>
    <h2 class="mb-4">Oops! Page Not Found</h2>
    <p class="lead mb-5">
      It looks like the Roblox code page you are looking for has been moved or doesn't exist.
    </p>
    <a href="/" class="btn btn-primary btn-lg">
      Go Back Home
    </a>
  </main>
</BaseLayout>