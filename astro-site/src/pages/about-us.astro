---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="About Us | GMEcodes" 
  description="Learn more about GMEcodes and why the site exists."

>
  <main class="container py-5">
    <div class="row justify-content-center">
      <div class="col-12 col-lg-8">
        <article class="card bg-dark text-white shadow-lg border-0">
          <div class="card-body p-4 p-lg-5">
            <p class="footer-kicker mb-2 text-info">About us</p>
            <h1 class="h2 mb-3">Why GMEcodes exists</h1>
            
            <p>GMEcodes was built to keep Roblox game codes easy to find, easy to read, and updated in one place.</p>
            
            <p>The goal is simple: less time digging through posts and videos, more time actually redeeming working codes and getting back in game.<p>
            
            <p>This site is maintained by a player who wanted a cleaner way to track active and expired codes across multiple games.</p>
            
            <a class="btn btn-primary mt-3 btn-lg" href="/">
              <i class="bi bi-house me-2"></i>Back Home
            </a>
          </div>
        </article>
      </div>
    </div>
  </main>
</BaseLayout>