---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGameCodesMeta, getGamePages } from '../../lib/site-data.js';

export function getStaticPaths() {
  return getGamePages().map((game) => ({
    params: { slug: game.slug },
    props: { game }
  }));
}

const { game } = Astro.props;
const meta = getGameCodesMeta();
const lastUpdated = game.lastUpdated || 'Recently';
const lastTested = game.lastTested || lastUpdated;
---
<BaseLayout
  title={game.title}
  description={game.metaDescription}
  canonical={game.canonical}
  ogType="article"
  ogTitle={game.title}
  ogDescription={game.ogDescription}
  ogUrl={game.canonical}
  ogImage={game.ogImage}
  bodyAttributes={{ 'data-comment-storage': game.commentStorage, 'data-game-id': game.gameId }}
  stylesheets={[
    'https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css',
    'https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css',
    '../css/rivals.css'
  ]}
>
  <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: rgb(42, 66, 92);">
    <div class="container">
      <a href="../index.html" class="navbar-brand fw-bold logo"><img src="../images/logo/Mainlogo.png" alt="GMEcodes logo" /></a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link" href="#L4"><i class="bi bi-gift me-1"></i>Codes</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#commentsSection"><i class="bi bi-people me-1"></i>Comment</a>
          </li>
        </ul>
        <ul class="navbar-nav ms-auto" id="userNav">
          <!-- User login/register or welcome message will be inserted here -->
        </ul>
      </div>
    </div>
  </nav>

  <header></header>
  <main class="container p-3 my-3 position-relative" id="L1" style={game.mainStyle || undefined}>
    <section class="row">
      <h1 class="text-center fw-bold">{game.heading}</h1>
      <p id="lastUpdatedLabel" class="text-center small text-info mb-2">Last updated: {lastUpdated}</p>
      <p id="testedTodayLabel" class="text-center small text-info mb-2">Tested: {lastTested}</p>
    </section>

    <section class="row" id="L2">
      <div class="col-12 col-sm-12 col-md-6">
        <img src={game.heroImage} alt={game.heroAlt} class="img-fluid my-3" loading="eager" decoding="async" fetchpriority="high" />
      </div>
      <div class="col-12 col-sm-12 col-md-6 my-auto related-slot">
        <div class="related-games-shell mt-2 mt-md-0">
          <h4>Related Roblox Code Pages</h4>
          <div class="related-games-links" id="relatedGamesLinks"></div>
        </div>
      </div>
    </section>

    <section class="row" id="L3">
      <div class="col-12 col-sm-12 col-md-6 my-auto">
        <h2 class="text-center my-4">{game.sectionHeading}</h2>
        <p class="szöveg">{game.intro}</p>
      </div>
    </section>

    <section class="row" id="L4">
      <div class="col-12 col-sm-12 col-md-6 my-auto">
        <h4 class="my-4">Working Codes:</h4>
        <ul class="list-group" id="workingCodesList">
          <li class="list-group-item">Verified active codes will appear here.</li>
        </ul>
      </div>
    </section>

    <section class="row" id="L4Expired">
      <div class="col-12 col-sm-12 col-md-6 my-auto">
        <h4 class="my-4">Expired Codes:</h4>
        <ul class="wp-block-list is-style-inline-divider-list" id="expiredCodesList">
          <li>Verified expired codes will appear here.</li>
        </ul>
      </div>
    </section>

    <section>
      <div class="col-12 col-sm-12 col-md-6 my-auto">
        <h4 class="my-4">{game.redeemHeading}</h4>
        <h5 class="szöv">{game.redeemLead}</h5>
        <ol class="list-group-numbered" id="redeemStepsList">
          {game.redeemSteps.map((step) => (
            <li class="list-group-item">{step}</li>
          ))}
        </ol>
      </div>
    </section>
  </main>

  <div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content bg-dark text-white">
        <div class="modal-header">
          <h5 class="modal-title" id="loginModalLabel">Login</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form id="loginForm">
            <div class="mb-3">
              <label for="loginUsername" class="form-label">Email or Username</label>
              <input type="text" class="form-control" id="loginUsername" placeholder="Owner: username or email, others: email" required />
            </div>
            <div class="mb-3">
              <label for="loginPassword" class="form-label">Password</label>
              <input type="password" class="form-control" id="loginPassword" required />
            </div>
            <button type="submit" class="btn btn-primary">Login</button>
          </form>
          <p class="mt-3 text-center">
            Don't have an account?
            <a href="#" data-bs-toggle="modal" data-bs-target="#registerModal" data-bs-dismiss="modal">Register here</a>
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="registerModal" tabindex="-1" aria-labelledby="registerModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content bg-dark text-white">
        <div class="modal-header">
          <h5 class="modal-title" id="registerModalLabel">Register Account</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form id="registerForm">
            <div class="mb-3">
              <label for="registerUsername" class="form-label">Username</label>
              <input type="text" class="form-control" id="registerUsername" required minlength="3" />
            </div>
            <div class="mb-3">
              <label for="registerEmail" class="form-label">Email</label>
              <input type="email" class="form-control" id="registerEmail" required />
            </div>
            <div class="mb-3">
              <label for="registerPassword" class="form-label">Password</label>
              <input type="password" class="form-control" id="registerPassword" required minlength="6" />
            </div>
            <div class="mb-3">
              <label for="confirmPassword" class="form-label">Confirm Password</label>
              <input type="password" class="form-control" id="confirmPassword" required />
            </div>
            <button type="submit" class="btn btn-success">Register</button>
          </form>
          <p class="mt-3 text-center">
            Already have an account?
            <a href="#" data-bs-toggle="modal" data-bs-target="#loginModal" data-bs-dismiss="modal">Login here</a>
          </p>
        </div>
      </div>
    </div>
  </div>

  <section id="commentsSection" class="container my-5" style="display: none;">
    <h3 class="text-center mb-4">Comments & Replies</h3>
    <div id="commentForm" class="mb-4">
      <h5>Leave a Comment</h5>
      <form id="addCommentForm">
        <div class="mb-3">
          <textarea class="form-control" id="commentText" rows="3" maxlength="100" placeholder="Write your comment..." required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Post Comment</button>
      </form>
    </div>
    <div id="commentsList"></div>
  </section>

  <section id="loginPrompt" class="container my-5 text-center" style="display: none;">
    <h3>Want to join the discussion?</h3>
    <p>Please log in or register to view and post comments.</p>
    <button class="btn btn-primary me-2" data-bs-toggle="modal" data-bs-target="#loginModal">Login</button>
    <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#registerModal">Register</button>
  </section>

  <footer class="site-footer">
    <div class="container footer-shell">
      <div class="footer-links">
        <h3>About this site</h3>
        <ul class="footer-link-list list-unstyled mb-0">
          <li><a href="../html/contact.html">Contact</a></li>
          <li><a href="../html/privacy-policy.html">Privacy Policy</a></li>
          <li><a href="../html/about-us.html">About Us</a></li>
        </ul>
      </div>
      <div class="footer-community">
        <h3>Community</h3>
        <p>Updates are posted here. They might stay blank, but i dont mind a follow..</p>
        <div class="footer-socials">
          <a href="https://www.youtube.com/channel/UCHYGN_cE8Bz070ZIw5MJF0A" target="_blank" rel="noopener noreferrer" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
          <a href="https://x.com/GMEcodes_com" target="_blank" rel="noopener noreferrer" aria-label="Twitter"><i class="bi bi-twitter"></i></a>
          <a href="https://www.instagram.com/gmecodes/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>GMEcodes</span>
      <span>Made by a player, for players</span>
    </div>
  </footer>

  <script is:inline src="../javascipt/game-codes.js"></script>
  <script is:inline src="../javascipt/rivals.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <script is:inline src="../javascipt/supabase-config.js"></script>
  <script is:inline src="../javascipt/auth.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</BaseLayout>
