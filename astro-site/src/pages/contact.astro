---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | GMEcodes" description="Contact GMEcodes to report problems or suggest features.">

>
  <main class="container py-5">
    <div class="row justify-content-center">
      <div class="col-12 col-lg-8">
        <article class="card bg-dark text-white shadow-lg border-0">
          <div class="card-body p-4 p-lg-5">
            <p class="footer-kicker mb-2 text-info">Contact</p>
            <h1 class="h2 mb-3">Get in touch</h1>
            <p>If you need to report a problem, suggest a feature, or ask a question about the site, use the links below.</p>
            
            <ul class="list-unstyled mb-4">
              <li class="mb-3">
                <i class="bi bi-envelope me-2 text-primary"></i>
                <a class="link-light text-decoration-none" href="mailto:gmecodes@gmail.com">gmecodes@gmail.com</a>
              </li>
              <li class="mb-3">
                <i class="bi bi-twitter me-2 text-primary"></i>
                <a class="link-light text-decoration-none" href="https://x.com/GMEcodes_com" target="_blank" rel="noopener noreferrer">@GMEcodes_com</a>
              </li>
              <li class="mb-3">
                <i class="bi bi-instagram me-2 text-primary"></i>
                <a class="link-light text-decoration-none" href="https://www.instagram.com/gmecodes/" target="_blank" rel="noopener noreferrer">@gmecodes</a>
              </li>
            </ul>
            
            <a class="btn btn-primary btn-lg" href="/">
              <i class="bi bi-house me-2"></i>Back Home
            </a>
          </div>
        </article>
      </div>
    </div>
  </main>


</BaseLayout>