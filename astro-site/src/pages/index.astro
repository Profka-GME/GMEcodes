---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHomeGames } from '../lib/site-data.js';

const homeGames = getHomeGames();
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'GMEcodes',
  url: 'https://gmecodes.com/',
  inLanguage: 'en'
};
---
<BaseLayout
  title="Roblox Game Codes | Working and Expired Codes | GMEcodes"
  description="Find working and expired Roblox game codes with regular updates, redeem steps, and dedicated pages for popular games."
  canonical="https://gmecodes.com/"
  ogTitle="Roblox Game Codes | GMEcodes"
  ogDescription="Find working and expired Roblox game codes with regular updates and dedicated game pages."
  ogUrl="https://gmecodes.com/"
  ogImage="https://gmecodes.com/images/logo/Mainlogo.png"
  bodyClass="home-page"
  stylesheets={[
    'https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css',
    'https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css',
    '/css/style.css'
  ]}
  schema={schema}
>
  <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: rgb(42, 66, 92);">
    <div class="container">
      <a href="/" class="navbar-brand fw-bold logo"><img src="images/logo/Mainlogo.png" alt="GMEcodes logo" /></a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto" id="userNav">
          <!-- User login/register or welcome message will be inserted here -->
        </ul>
      </div>
    </div>
  </nav>

  <section class="hero">
    <h1>Roblox Game Codes</h1>
    <p>Find working and expired codes for popular Roblox games with regular updates.</p>

    <div class="search-container">
      <input
        type="text"
        id="search-input"
        placeholder="Search for games..."
        autocomplete="off"
      />

      <div id="search-results"></div>
    </div>
  </section>

  <section class="latest-updates" aria-labelledby="latestUpdatesTitle">
    <div class="container">
      <div class="latest-updates-header">
        <h2 id="latestUpdatesTitle">Latest Code Updates</h2>
        <p>Freshly updated game code pages. Check these first.</p>
      </div>
      <div class="latest-updates-grid" id="latestUpdatesList">
        <article class="update-card"><h3>Loading updates...</h3></article>
      </div>
    </div>
  </section>

  <section class="latest-updates" aria-labelledby="browseGamesTitle">
    <div class="container">
      <div class="latest-updates-header">
        <h2 id="browseGamesTitle">Browse All Game Code Pages</h2>
        <p>Direct links to every indexed code page on the site.</p>
      </div>
      <div class="row g-3" id="browseGamesList">
        {homeGames.map((game) => (
          <div class="col-12 col-md-6 col-xl-4">
            <article class="update-card h-100">
              <h3><a href={game.page}>{game.title}</a></h3>
              <p class="update-stats">{game.summary}</p>
            </article>
          </div>
        ))}
      </div>
      <nav class="d-flex justify-content-center mt-4" aria-label="Browse game pages pagination" id="browseGamesPagination" hidden>
        <ul class="pagination mb-0">
          <li class="page-item" id="browsePrevPageItem">
            <button class="page-link" type="button" id="browsePrevPageBtn">Previous</button>
          </li>
          <li class="page-item disabled">
            <span class="page-link" id="browsePageIndicator">Page 1 of 1</span>
          </li>
          <li class="page-item" id="browseNextPageItem">
            <button class="page-link" type="button" id="browseNextPageBtn">Next</button>
          </li>
        </ul>
      </nav>
    </div>
  </section>

  <div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered auth-modal-dialog">
      <div class="modal-content auth-modal-content text-white">
        <div class="modal-header auth-modal-header">
          <h5 class="modal-title auth-modal-title" id="loginModalLabel"><i class="bi bi-shield-lock-fill me-2"></i>Secure Login</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body auth-modal-body">
          <p class="auth-modal-subtitle">Sign in to access your profile and game tools.</p>
          <form id="loginForm">
            <div class="mb-3">
              <label for="loginUsername" class="form-label"><i class="bi bi-person me-2"></i>Email or Username</label>
              <input type="text" class="form-control auth-input" id="loginUsername" placeholder="Owner: username or email, others: email" required />
            </div>
            <div class="mb-3">
              <label for="loginPassword" class="form-label"><i class="bi bi-lock me-2"></i>Password</label>
              <input type="password" class="form-control auth-input" id="loginPassword" required />
            </div>
            <div class="d-grid">
              <button type="submit" class="btn btn-primary auth-primary-btn"><i class="bi bi-box-arrow-in-right me-2"></i>Login</button>
            </div>
          </form>
          <p class="mt-3 text-center auth-switch-text">
            Don't have an account?
            <a href="#" class="auth-link-switch" data-bs-toggle="modal" data-bs-target="#registerModal" data-bs-dismiss="modal">Register here</a>
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="registerModal" tabindex="-1" aria-labelledby="registerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered auth-modal-dialog">
      <div class="modal-content auth-modal-content text-white">
        <div class="modal-header auth-modal-header">
          <h5 class="modal-title auth-modal-title" id="registerModalLabel"><i class="bi bi-person-plus-fill me-2"></i>Create Account</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body auth-modal-body">
          <p class="auth-modal-subtitle">Use a valid email to receive your verification code.</p>
          <form id="registerForm">
            <div class="mb-3">
              <label for="registerUsername" class="form-label"><i class="bi bi-person-badge me-2"></i>Username</label>
              <input type="text" class="form-control auth-input" id="registerUsername" required minlength="3" />
            </div>
            <div class="mb-3">
              <label for="registerEmail" class="form-label"><i class="bi bi-envelope me-2"></i>Email</label>
              <input type="email" class="form-control auth-input" id="registerEmail" required />
            </div>
            <div class="mb-3">
              <label for="registerPassword" class="form-label"><i class="bi bi-key me-2"></i>Password</label>
              <input type="password" class="form-control auth-input" id="registerPassword" required minlength="6" />
            </div>
            <div class="mb-3">
              <label for="confirmPassword" class="form-label"><i class="bi bi-check2-circle me-2"></i>Confirm Password</label>
              <input type="password" class="form-control auth-input" id="confirmPassword" required />
            </div>
            <div class="d-grid">
              <button type="submit" class="btn btn-success auth-primary-btn"><i class="bi bi-person-check me-2"></i>Register</button>
            </div>
          </form>
          <p class="mt-3 text-center auth-switch-text">
            Already have an account?
            <a href="#" class="auth-link-switch" data-bs-toggle="modal" data-bs-target="#loginModal" data-bs-dismiss="modal">Login here</a>
          </p>
        </div>
      </div>
    </div>
  </div>

  <footer class="site-footer" id="contacts">
    <div class="container footer-shell">
      <div class="footer-links">
        <h3>About this site</h3>
        <ul class="footer-link-list list-unstyled mb-0">
          <li><a href="html/contact.html">Contact</a></li>
          <li><a href="html/privacy-policy.html">Privacy Policy</a></li>
          <li><a href="html/about-us.html">About Us</a></li>
        </ul>
      </div>

      <div class="footer-community">
        <h3>Community</h3>
        <p>Updates are posted here. They might stay blank, but i dont mind a follow..</p>
        <div class="footer-socials">
          <a href="https://www.youtube.com/channel/UCHYGN_cE8Bz070ZIw5MJF0A" target="_blank" rel="noopener noreferrer" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
          <a href="https://x.com/GMEcodes_com" target="_blank" rel="noopener noreferrer" aria-label="Twitter"><i class="bi bi-twitter"></i></a>
          <a href="https://www.instagram.com/gmecodes/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>GMEcodes</span>
      <span>Made by a player, for players</span>
    </div>
  </footer>

  <script is:inline src="/javascipt/search.js"></script>
  <script is:inline src="/javascipt/home-updates.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <script is:inline src="/javascipt/supabase-config.js"></script>
  <script is:inline src="/javascipt/auth.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</BaseLayout>
