---
const {
  lang = 'en',
  title,
  description,
  canonical,
  ogType = 'website',
  ogTitle = title,
  ogDescription = description,
  ogUrl = canonical,
  ogImage = 'https://gmecodes.com/images/logo/Mainlogo.png',
  bodyClass = '',
  bodyAttributes = {},
  stylesheets = [],
  schema = null
} = Astro.props;

const schemaJson = schema ? JSON.stringify(schema, null, 2) : '';
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="GMEcodes" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@GMEcodes_com" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    {stylesheets.map((href) => <link rel="stylesheet" href={href} />)}
    <link rel="icon" type="image/png" href="/images/logo/Mainlogo.png" />
    <script defer src="/_vercel/insights/script.js"></script>
    <script defer src="/_vercel/speed-insights/script.js"></script>
    {schemaJson && <script type="application/ld+json" set:html={schemaJson}></script>}
    <slot name="head" />
  </head>
  <body class={bodyClass} {...bodyAttributes}>
    <slot />
  </body>
</html>
