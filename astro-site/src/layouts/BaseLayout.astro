---
const {
  lang = 'en',
  title = 'GMEcodes - Latest Game Codes',
  description = 'Find the latest working codes for your favorite games.',
  canonical,
  ogType = 'website',
  ogTitle = title,
  ogDescription = description,
  ogUrl = canonical,
  ogImage = 'https://gmecodes.com/images/logo/Mainlogo.png',
  bodyClass = '',
  bodyAttributes = {},
  stylesheets = [],
  schema = null
} = Astro.props;

const schemaJson = schema ? JSON.stringify(schema, null, 2) : '';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="GMEcodes" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@GMEcodes_com" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    
    {stylesheets.map((href) => <link rel="stylesheet" href={href} />)}

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.png" sizes="48x48" type="image/png" />
    <link rel="apple-touch-icon" href="/images/logo/Mainlogo.png" />

    <script defer src="/_vercel/insights/script.js"></script>
    <script defer src="/_vercel/speed-insights/script.js"></script>
    {schemaJson && <script type="application/ld+json" set:html={schemaJson}></script>}
    
    <slot name="head" />

  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-JTKXQYYKCQ"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-JTKXQYYKCQ');
  </script>

</head>
<body class={bodyClass} {...bodyAttributes}> 

  <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: rgb(42, 66, 92);">
    <div class="container">
      <a href="/" class="navbar-brand fw-bold logo"><img src="/images/logo/Mainlogo.png" alt="GMEcodes logo" /></a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto" id="userNav">
          <!-- User login/register or welcome message will be inserted here -->
        </ul>
      </div>
    </div>
  </nav>


    <main>
        <slot />
    </main>

     <footer class="site-footer" id="contacts">
    <div class="container footer-shell">
      <div class="footer-links">
        <h3>About this site</h3>
        <ul class="footer-link-list list-unstyled mb-0">
          <li><a href="/contact">Contact</a></li>
          <li><a href="/privacy-policy">Privacy Policy</a></li>
          <li><a href="/about-us">About Us</a></li>
        </ul>
      </div>

      <div class="footer-community">
        <h3>Community</h3>
        <p>Updates are posted here. They might stay blank, but i dont mind a follow..</p>
        <div class="footer-socials">
          <a href="https://www.youtube.com/channel/UCHYGN_cE8Bz070ZIw5MJF0A" target="_blank" rel="noopener noreferrer" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
          <a href="https://x.com/GMEcodes_com" target="_blank" rel="noopener noreferrer" aria-label="Twitter"><i class="bi bi-twitter"></i></a>
          <a href="https://www.instagram.com/gmecodes/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>GMEcodes</span>
      <span>Made by a player, for players</span>
    </div>
  </footer>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script is:inline>
      function updateNavbar() {
        const navSection = document.getElementById('navAuthSection');
        if (!navSection) return;

        // Check login status from localStorage
        const loggedIn = localStorage.getItem('loggedIn') === 'true';
        const username = localStorage.getItem('currentUser'); 

        if (loggedIn && username) {
          navSection.innerHTML = `
            <div class="dropdown">
              <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person-circle me-2"></i>Welcome, ${username}
              </button>
              <ul class="dropdown-menu dropdown-menu-end shadow">
                <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
              </ul>
            </div>`;
        } else {
          navSection.innerHTML = `<a href="/login" class="btn btn-primary">Login / Register</a>`;
        }
      }

      // Initial run
      updateNavbar();

      // Listen for login/logout events across the site
      window.addEventListener('userLoggedIn', updateNavbar);
      window.addEventListener('userLoggedOut', updateNavbar);
      </script>

      <script is:inline src="/javascipt/search.js"></script>
      <script is:inline src="/javascipt/home-updates.js"></script>
      <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
      <script is:inline src="/javascipt/supabase-config.js"></script>
      <script is:inline src="/javascipt/auth.js"></script>
      <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
      <script is:inline src="/javascipt/profile.js"></script>
</body>
</html>